TOKEN=YOUR_DISCORD_BOT_TOKEN
CLIENTID=YOUR_DISCORD_APPLICATION_ID
CLIENT_SECRET=YOUR_DISCORD_CLIENT_SECRET
MONGO_URI=YOUR_MONGODB_CONNECTION_STRING
GROQ_API_KEY=YOUR_GROQ_API_KEY
REDIS_URL=
JWT_SECRET=YOUR_LONG_RANDOM_SECRET
APP_URL=https://your-vercel-project.vercel.app
REDIRECT_URI=http://YOUR_BACKEND_IP:YOUR_BACKEND_PORT/api/auth/callback
API_PORT=YOUR_ASSIGNED_PANEL_PORT
SERVER_PORT=YOUR_ASSIGNED_PANEL_PORT
PORT=YOUR_ASSIGNED_PANEL_PORT

# Notes:
# APP_URL should be your live Vercel frontend URL
# REDIRECT_URI must exactly match the value added in the Discord Developer Portal
# Use your panel-assigned backend port, not a random custom port
